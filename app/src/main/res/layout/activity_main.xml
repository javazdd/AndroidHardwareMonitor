<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sending metrics every 30 s"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="32dp" />

        <!-- Battery card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BATTERY"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tvBatteryPct"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tvBatteryTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Battery Temp: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- CPU card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPERATURE"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tvCpuTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CPU Temp: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Signal card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIGNAL"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tvSignal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Signal: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- System card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tvRam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RAM: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/tvStorage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Storage: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Connectivity card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTIVITY"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="8dp" />
                <TextView
                    android:id="@+id/tvConnectivity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connectivity: —"
                    android:textSize="18sp"
                    android:textColor="#1A1A2E" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Springshot API status card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPRINGSHOT APIs"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <!-- summary row: dot + "N/9 UP" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/viewApiDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/dot_grey"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvApiSummary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Checking…"
                        android:textSize="16sp"
                        android:textColor="#1A1A2E" />
                </LinearLayout>

                <!-- per-endpoint detail rows (filled programmatically) -->
                <LinearLayout
                    android:id="@+id/llApiEndpoints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tvApiLastChecked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last checked: —"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Datadog send-status card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/cardDdogStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATADOG"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textColor="#999999"
                    android:layout_marginBottom="10dp" />

                <!-- dot + status message on the same row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <View
                        android:id="@+id/viewDdogDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/dot_grey"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvDdogStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Waiting for first send…"
                        android:textSize="16sp"
                        android:textColor="#1A1A2E" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDdogLastSent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Last sent: —"
                    android:textSize="13sp"
                    android:textColor="#888888" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status footer -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing…"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
