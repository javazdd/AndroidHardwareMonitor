<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- MDM managed banner — hidden unless SOTI pushes a config -->
        <TextView
            android:id="@+id/tvMdmBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:background="#1A3A6B"
            android:padding="14dp"
            android:layout_marginBottom="20dp"
            android:text="⚙ Managed by MDM — settings are controlled by your SOTI policy and cannot be edited on-device."
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <!-- ── BACKEND SITE ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BACKEND SITE"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">
                <Spinner
                    android:id="@+id/spinnerSite"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── EMISSION INTERVAL ──────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMISSION INTERVAL"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">
                <Spinner
                    android:id="@+id/spinnerInterval"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How often metrics are read and sent. Events are queued and flushed at each window."
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="24dp" />

        <!-- ── BACKEND API KEY ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BACKEND API KEY"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <!-- TextInputLayout provides the built-in show/hide eye toggle -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            app:endIconContentDescription="Toggle API key visibility"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Paste your backend API key here"
                android:inputType="textPassword"
                android:fontFamily="monospace"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Find yours in your backend's organization or API settings"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="24dp" />

        <!-- ── DEVICE ID ────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEVICE ID"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <EditText
                android:id="@+id/etDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:hint="e.g. samsung_s23_ultra"
                android:textSize="16sp"
                android:inputType="textNoSuggestions"
                android:background="@null" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sent as device:{id} on every metric and event"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="24dp" />

        <!-- ── HARDWARE TAGS (auto-detected) ──────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HARDWARE TAGS"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Auto-detected from device — always included"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <TextView
                android:id="@+id/tvHardwareTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.5" />
        </androidx.cardview.widget.CardView>

        <!-- ── CUSTOM TAGS ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CUSTOM TAGS"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Up to 5 additional key:value tags (e.g.  env:prod  site:warehouse_a)"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- Row 0 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <EditText android:id="@+id/etTagKey0"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="key" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" : " android:textSize="16sp" android:textColor="#BBBBBB" />
                    <EditText android:id="@+id/etTagValue0"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="value" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="4dp"/>

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <EditText android:id="@+id/etTagKey1"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="key" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" : " android:textSize="16sp" android:textColor="#BBBBBB" />
                    <EditText android:id="@+id/etTagValue1"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="value" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="4dp"/>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <EditText android:id="@+id/etTagKey2"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="key" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" : " android:textSize="16sp" android:textColor="#BBBBBB" />
                    <EditText android:id="@+id/etTagValue2"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="value" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="4dp"/>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <EditText android:id="@+id/etTagKey3"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="key" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" : " android:textSize="16sp" android:textColor="#BBBBBB" />
                    <EditText android:id="@+id/etTagValue3"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="value" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="4dp"/>

                <!-- Row 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <EditText android:id="@+id/etTagKey4"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="key" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text=" : " android:textSize="16sp" android:textColor="#BBBBBB" />
                    <EditText android:id="@+id/etTagValue4"
                        android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                        android:hint="value" android:textSize="13sp" android:padding="8dp"
                        android:inputType="textNoSuggestions" android:background="@null" android:fontFamily="monospace" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leave any row blank to skip it"
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="40dp" />

        <!-- ── DEBUG LOGGING ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEBUG LOGGING"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textColor="#888888"
            android:layout_marginBottom="6dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send diagnostic logs to backend"
                        android:textSize="15sp"
                        android:textColor="#222222" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logs service lifecycle, events, errors, and HTTP failures. Disable when not needed."
                        android:textSize="12sp"
                        android:textColor="#999999"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDebugLogging"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Only enable when diagnosing issues — each log entry is an additional network call."
            android:textSize="12sp"
            android:textColor="#999999"
            android:layout_marginBottom="32dp" />

        <!-- ── Buttons ─────────────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save &amp; Restart Monitoring"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnDiscard"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Discard"
            android:textSize="15sp"
            style="?attr/borderlessButtonStyle"
            android:textColor="#888888" />

    </LinearLayout>
</ScrollView>
